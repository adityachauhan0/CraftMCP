<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:model="using:CraftMCP.App.Models"
        mc:Ignorable="d"
        x:Class="CraftMCP.App.Dialogs.NewDocumentDialog"
        x:CompileBindings="False"
        Width="420"
        Height="520"
        MinWidth="420"
        MinHeight="520"
        Title="New Document">
    <Grid RowDefinitions="Auto,Auto,*,Auto"
          Margin="20">
        <TextBlock Text="New Document"
                   FontSize="24"
                   FontWeight="SemiBold" />

        <StackPanel Grid.Row="1"
                    Margin="0,16,0,16"
                    Spacing="8">
            <TextBlock Text="Document Name" />
            <TextBox x:Name="DocumentNameTextBox"
                     Watermark="Untitled" />
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Spacing="8">
            <TextBlock Text="Preset" />
            <ListBox x:Name="PresetListBox"
                     Height="220" />

            <Grid ColumnDefinitions="*,*"
                  Margin="0,12,0,0">
                <StackPanel Grid.Column="0"
                            Margin="0,0,8,0"
                            Spacing="8">
                    <TextBlock Text="Width" />
                    <TextBox x:Name="WidthTextBox" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Margin="8,0,0,0"
                            Spacing="8">
                    <TextBlock Text="Height" />
                    <TextBox x:Name="HeightTextBox" />
                </StackPanel>
            </Grid>
        </StackPanel>

        <Grid Grid.Row="3"
              ColumnDefinitions="*,*"
              Margin="0,20,0,0">
            <Button Grid.Column="0"
                    Margin="0,0,8,0"
                    Content="Cancel"
                    Click="OnCancelClick" />
            <Button Grid.Column="1"
                    Margin="8,0,0,0"
                    Content="Create"
                    Click="OnCreateClick" />
        </Grid>
    </Grid>
</Window>
