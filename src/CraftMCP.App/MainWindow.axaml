<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="using:CraftMCP.App.Controls"
        xmlns:vm="using:CraftMCP.App.ViewModels"
        mc:Ignorable="d"
        d:DesignWidth="1440"
        d:DesignHeight="900"
        x:Class="CraftMCP.App.MainWindow"
        x:CompileBindings="False"
        Width="1440"
        Height="900"
        MinWidth="1120"
        MinHeight="720"
        Title="{Binding DocumentTitle}">
    <Grid Background="#120F0D"
          RowDefinitions="Auto,*">
        <Border Grid.Row="0"
                Margin="18,18,18,0"
                Padding="20,18"
                Background="#CC211A16"
                BorderBrush="#26F0C898"
                BorderThickness="1"
                CornerRadius="28">
            <StackPanel Spacing="16">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="18">
                    <StackPanel Orientation="Horizontal"
                                Spacing="14">
                        <Border Width="42"
                                Height="42"
                                Background="#F0C898"
                                CornerRadius="14">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="C"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#1A130F" />
                        </Border>
                        <StackPanel Spacing="2">
                            <TextBlock Text="CraftMCP"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="#F6EFE7" />
                            <TextBlock Text="Agent-native creative workstation"
                                       Foreground="#B8A99A"
                                       FontSize="12" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Spacing="6">
                        <TextBlock Text="{Binding DocumentTitle}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#F6EFE7" />
                        <WrapPanel>
                            <Border Margin="0,0,8,8"
                                    Padding="12,8"
                                    Background="#291F1A"
                                    BorderBrush="#19FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="999">
                                <TextBlock Text="{Binding WorkspaceContextText}"
                                           Foreground="#E8DDD3"
                                           FontSize="12" />
                            </Border>
                            <Border Margin="0,0,8,8"
                                    Padding="12,8"
                                    Background="#1D1714"
                                    BorderBrush="#19FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="999">
                                <TextBlock Text="{Binding WorkspaceStateText}"
                                           Foreground="#F0C898"
                                           FontSize="12" />
                            </Border>
                            <Border Margin="0,0,8,8"
                                    Padding="12,8"
                                    Background="#162132"
                                    BorderBrush="#332D9BF0"
                                    BorderThickness="1"
                                    CornerRadius="999">
                                <TextBlock Text="Review-first mutation model"
                                           Foreground="#9AC5FF"
                                           FontSize="12" />
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="2"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Spacing="6">
                        <TextBlock Text="Workspace status"
                                   Foreground="#B8A99A"
                                   FontSize="11" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   MaxWidth="320"
                                   TextWrapping="Wrap"
                                   Foreground="#F6EFE7"
                                   FontSize="13" />
                    </StackPanel>
                </Grid>
                <Grid ColumnDefinitions="Auto,Auto,Auto,*"
                      ColumnSpacing="12">
                    <Border Padding="10,8"
                            Background="#1B1512"
                            BorderBrush="#19FFFFFF"
                            BorderThickness="1"
                            CornerRadius="18">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <Button Content="New" Click="OnNewClick" />
                            <Button Content="Open" Click="OnOpenClick" />
                            <Button Content="Save" Click="OnSaveClick" />
                            <Button Content="Save As" Click="OnSaveAsClick" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1"
                            Padding="10,8"
                            Background="#1B1512"
                            BorderBrush="#19FFFFFF"
                            BorderThickness="1"
                            CornerRadius="18">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <Button Content="Export PNG" Click="OnExportPngClick" />
                            <Button Content="Export JSON" Click="OnExportJsonClick" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2"
                            Padding="10,8"
                            Background="#1B1512"
                            BorderBrush="#19FFFFFF"
                            BorderThickness="1"
                            CornerRadius="18">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <Button Content="Undo"
                                    IsEnabled="{Binding CanUndo}"
                                    Click="OnUndoClick" />
                            <Button Content="Redo"
                                    IsEnabled="{Binding CanRedo}"
                                    Click="OnRedoClick" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3"
                            Padding="14,10"
                            Background="#17120F"
                            BorderBrush="#19FFFFFF"
                            BorderThickness="1"
                            CornerRadius="18">
                        <TextBlock Text="Current MVP file, export, and history actions stay reachable here after the redesign."
                                   TextWrapping="Wrap"
                                   Foreground="#B8A99A"
                                   FontSize="12" />
                    </Border>
                </Grid>
            </StackPanel>
        </Border>
        <Grid Grid.Row="1"
              Margin="18"
              ColumnDefinitions="340,*,380"
              ColumnSpacing="18">
            <Border Grid.Column="0"
                    Padding="18"
                    Background="#F015100E"
                    BorderBrush="#26F0C898"
                    BorderThickness="1"
                    CornerRadius="28">
                <ScrollViewer>
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Agent Workspace"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="#F6EFE7" />
                            <TextBlock Text="Prompt, proposal review, and activity stay visible beside the canvas."
                                       TextWrapping="Wrap"
                                       Foreground="#B8A99A"
                                       FontSize="12" />
                        </StackPanel>
                        <Border Padding="16"
                                Background="#CC231B18"
                                BorderBrush="#33F0C898"
                                BorderThickness="1"
                                CornerRadius="22">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="12">
                                    <TextBlock Text="Prompt Composer"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="#F6EFE7" />
                                    <Border Grid.Column="1"
                                            Padding="10,6"
                                            Background="#1C1714"
                                            BorderBrush="#19FFFFFF"
                                            BorderThickness="1"
                                            CornerRadius="999">
                                        <TextBlock Text="{Binding PromptScopeText}"
                                                   Foreground="#F0C898"
                                                   FontSize="11" />
                                    </Border>
                                </Grid>
                                <TextBlock Text="{Binding PromptExpectationText}"
                                           Foreground="#B8A99A"
                                           FontSize="12" />
                                <TextBox AcceptsReturn="True"
                                         Height="96"
                                         Text="{Binding PromptText}"
                                         Watermark="Describe the change you want the planner to propose." />
                                <Button Content="Plan Proposal"
                                        IsEnabled="{Binding CanSubmitPrompt}"
                                        Click="OnSubmitPromptClick" />
                            </StackPanel>
                        </Border>
                        <Border Padding="16"
                                Background="#B8140F0D"
                                BorderBrush="#19FFFFFF"
                                BorderThickness="1"
                                CornerRadius="22">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Agents + Capability Surface"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#F6EFE7" />
                                <TextBlock Text="{Binding PlannerSurfaceText}"
                                           Foreground="#9AC5FF"
                                           FontSize="12" />
                                <TextBlock Text="{Binding McpSurfaceText}"
                                           Foreground="#D7CCC2"
                                           TextWrapping="Wrap"
                                           FontSize="12" />
                            </StackPanel>
                        </Border>
                        <Border Padding="16"
                                Background="#B8140F0D"
                                BorderBrush="#19FFFFFF"
                                BorderThickness="1"
                                CornerRadius="22">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Proposal Review"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#F6EFE7" />
                                <TextBlock Text="{Binding ProposalStatusText}"
                                           Foreground="#E8DDD3"
                                           FontSize="12" />
                                <TextBlock Text="{Binding ProposalSummaryText}"
                                           Foreground="#F6EFE7"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding ProposalRationaleText}"
                                           IsVisible="{Binding HasProposalRationale}"
                                           Foreground="#D7CCC2"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding ProposalCommandPreviewText}"
                                           IsVisible="{Binding HasProposal}"
                                           Foreground="#E8DDD3"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding ProposalIssueText}"
                                           IsVisible="{Binding HasProposalIssues}"
                                           Foreground="#F0C898"
                                           TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8">
                                    <Button Content="Approve"
                                            IsEnabled="{Binding CanApproveProposal}"
                                            Click="OnApproveProposalClick" />
                                    <Button Content="Reject"
                                            IsEnabled="{Binding CanRejectProposal}"
                                            Click="OnRejectProposalClick" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Padding="16"
                                Background="#B8140F0D"
                                BorderBrush="#19FFFFFF"
                                BorderThickness="1"
                                CornerRadius="22">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Activity Timeline"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#F6EFE7" />
                                <ItemsControl ItemsSource="{Binding ActivityEntries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10"
                                                    Padding="12"
                                                    Background="#120E0C"
                                                    BorderBrush="#19FFFFFF"
                                                    BorderThickness="1"
                                                    CornerRadius="18">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Text="{Binding TimestampLabel}"
                                                               Foreground="#9D9085"
                                                               FontSize="11" />
                                                    <TextBlock Text="{Binding Summary}"
                                                               Foreground="#F6EFE7"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding DetailText}"
                                                               Foreground="#D7CCC2"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding MetaLabel}"
                                                               Foreground="#9D9085"
                                                               FontSize="11"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
            <Border Grid.Column="1"
                    Padding="14"
                    Background="#F0120F0D"
                    BorderBrush="#19FFFFFF"
                    BorderThickness="1"
                    CornerRadius="30">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="14">
                    <Border Padding="10"
                            Background="#B81B1613"
                            BorderBrush="#19FFFFFF"
                            BorderThickness="1"
                            CornerRadius="22">
                        <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto"
                              ColumnSpacing="8">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <Button Content="Select"
                                        Tag="Select"
                                        Click="OnToolClick" />
                                <Button Content="Pan"
                                        Tag="Pan"
                                        Click="OnToolClick" />
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                <Button Content="Rect"
                                        Tag="CreateRectangle"
                                        Click="OnToolClick" />
                                <Button Content="Circle"
                                        Tag="CreateCircle"
                                        Click="OnToolClick" />
                                <Button Content="Line"
                                        Tag="CreateLine"
                                        Click="OnToolClick" />
                                <Button Content="Text"
                                        Tag="CreateText"
                                        Click="OnToolClick" />
                                <Button Content="Image"
                                        Click="OnImageToolClick" />
                            </StackPanel>
                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                <Button Content="Duplicate" Click="OnDuplicateSelectionClick" />
                                <Button Content="Delete" Click="OnDeleteSelectionClick" />
                                <Button Content="Group" Click="OnGroupSelectionClick" />
                                <Button Content="Ungroup" Click="OnUngroupSelectionClick" />
                            </StackPanel>
                            <Border Grid.Column="4"
                                    Padding="10,6"
                                    Background="#1D1714"
                                    BorderBrush="#19FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="999">
                                <TextBlock Text="{Binding ActiveToolText}"
                                           Foreground="#F0C898"
                                           FontSize="11" />
                            </Border>
                            <Border Grid.Column="5"
                                    Padding="10,6"
                                    Background="#162132"
                                    BorderBrush="#332D9BF0"
                                    BorderThickness="1"
                                    CornerRadius="999">
                                <TextBlock Text="{Binding SelectionSummaryText}"
                                           Foreground="#9AC5FF"
                                           FontSize="11" />
                            </Border>
                        </Grid>
                    </Border>
                    <Border Grid.Row="1"
                            Padding="22"
                            Background="#0E0B09"
                            BorderBrush="#19FFFFFF"
                            BorderThickness="1"
                            CornerRadius="28">
                        <Grid RowDefinitions="Auto,Auto,*"
                              RowSpacing="14">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Canvas Stage"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="#F6EFE7" />
                                    <TextBlock Text="The artboard stays central while review-first agent work remains visible in the shell."
                                               TextWrapping="Wrap"
                                               Foreground="#B8A99A"
                                               FontSize="12" />
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Padding="10,6"
                                        Background="#1C1714"
                                        BorderBrush="#19FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="999">
                                    <TextBlock Text="{Binding WorkspaceStateText}"
                                               Foreground="#F0C898"
                                               FontSize="11" />
                                </Border>
                            </Grid>
                            <Border Grid.Row="1"
                                    Padding="12"
                                    Background="#140F0D"
                                    BorderBrush="#19FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="16">
                                <TextBlock Text="{Binding RenderWarningsText}"
                                           Foreground="#F0C898"
                                           TextWrapping="Wrap" />
                            </Border>
                            <Border Grid.Row="2"
                                    Padding="18"
                                    Background="#181411"
                                    BorderBrush="#26FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="28">
                                <controls:WorkspaceCanvasControl />
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
            <Border Grid.Column="2"
                    Padding="18"
                    Background="#F015100E"
                    BorderBrush="#26F0C898"
                    BorderThickness="1"
                    CornerRadius="28">
                <ScrollViewer>
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Inspector"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="#F6EFE7" />
                            <TextBlock Text="{Binding AgentContextSummaryText}"
                                       TextWrapping="Wrap"
                                       Foreground="#B8A99A"
                                       FontSize="12" />
                        </StackPanel>
                        <Border Padding="16"
                                Background="#B8140F0D"
                                BorderBrush="#19FFFFFF"
                                BorderThickness="1"
                                CornerRadius="22">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Design"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#F6EFE7" />
                                <TextBlock Text="{Binding SelectionSummaryText}"
                                           Foreground="#D7CCC2"
                                           TextWrapping="Wrap" />
                                <StackPanel IsVisible="{Binding ShowCanvasEditor}"
                                            Spacing="8">
                                    <TextBlock Text="Canvas" FontWeight="SemiBold" />
                                    <TextBox Watermark="Width" Text="{Binding CanvasWidthText}" />
                                    <TextBox Watermark="Height" Text="{Binding CanvasHeightText}" />
                                    <TextBox Watermark="#RRGGBB" Text="{Binding CanvasBackgroundText}" />
                                    <Button Content="Apply Canvas" Click="OnApplyCanvasClick" />
                                </StackPanel>
                                <StackPanel IsVisible="{Binding ShowSingleNodeEditor}"
                                            Spacing="8">
                                    <TextBlock Text="Selection" FontWeight="SemiBold" />
                                    <TextBox Watermark="Name" Text="{Binding NameText}" />
                                    <Grid ColumnDefinitions="*,*"
                                          ColumnSpacing="8">
                                        <TextBox Grid.Column="0" Watermark="X" Text="{Binding XText}" />
                                        <TextBox Grid.Column="1" Watermark="Y" Text="{Binding YText}" />
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*"
                                          ColumnSpacing="8">
                                        <TextBox Grid.Column="0" Watermark="Rotation" Text="{Binding RotationText}" />
                                        <TextBox Grid.Column="1" Watermark="Opacity" Text="{Binding OpacityText}" />
                                    </Grid>
                                    <StackPanel IsVisible="{Binding ShowShapeEditor}" Spacing="8">
                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                            <TextBox Grid.Column="0" Watermark="Width" Text="{Binding WidthText}" />
                                            <TextBox Grid.Column="1" Watermark="Height" Text="{Binding HeightText}" />
                                        </Grid>
                                        <TextBox Watermark="Fill #RRGGBB" Text="{Binding FillText}" />
                                        <TextBox Watermark="Stroke #RRGGBB" Text="{Binding StrokeText}" />
                                        <TextBox Watermark="Stroke width" Text="{Binding StrokeWidthText}" />
                                        <TextBox Watermark="Corner radius" Text="{Binding CornerRadiusText}" />
                                    </StackPanel>
                                    <StackPanel IsVisible="{Binding ShowTextEditor}" Spacing="8">
                                        <TextBox AcceptsReturn="True"
                                                 Height="80"
                                                 Text="{Binding TextContent}" />
                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                            <TextBox Grid.Column="0" Watermark="Width" Text="{Binding WidthText}" />
                                            <TextBox Grid.Column="1" Watermark="Height" Text="{Binding HeightText}" />
                                        </Grid>
                                        <TextBox Watermark="Fill #RRGGBB" Text="{Binding FillText}" />
                                        <TextBox Watermark="Font family" Text="{Binding FontFamilyText}" />
                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                            <TextBox Grid.Column="0" Watermark="Font size" Text="{Binding FontSizeText}" />
                                            <TextBox Grid.Column="1" Watermark="Weight" Text="{Binding FontWeightText}" />
                                        </Grid>
                                        <TextBox Watermark="Alignment" Text="{Binding AlignmentText}" />
                                    </StackPanel>
                                    <StackPanel IsVisible="{Binding ShowImageEditor}" Spacing="8">
                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                            <TextBox Grid.Column="0" Watermark="Width" Text="{Binding WidthText}" />
                                            <TextBox Grid.Column="1" Watermark="Height" Text="{Binding HeightText}" />
                                        </Grid>
                                        <TextBox Watermark="Fit mode" Text="{Binding FitModeText}" />
                                    </StackPanel>
                                    <StackPanel IsVisible="{Binding ShowLineEditor}" Spacing="8">
                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                            <TextBox Grid.Column="0" Watermark="Start X" Text="{Binding StartXText}" />
                                            <TextBox Grid.Column="1" Watermark="Start Y" Text="{Binding StartYText}" />
                                        </Grid>
                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                            <TextBox Grid.Column="0" Watermark="End X" Text="{Binding EndXText}" />
                                            <TextBox Grid.Column="1" Watermark="End Y" Text="{Binding EndYText}" />
                                        </Grid>
                                        <TextBox Watermark="Stroke #RRGGBB" Text="{Binding StrokeText}" />
                                        <TextBox Watermark="Stroke width" Text="{Binding StrokeWidthText}" />
                                    </StackPanel>
                                    <Button Content="Apply Selection" Click="OnApplySelectionClick" />
                                </StackPanel>
                                <StackPanel IsVisible="{Binding ShowMultiSelectionEditor}"
                                            Spacing="8">
                                    <TextBlock Text="Multi-select edits remain command-backed. Use the center command bar for group, duplicate, and delete."
                                               TextWrapping="Wrap"
                                               Foreground="#D7CCC2" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Padding="16"
                                Background="#B8140F0D"
                                BorderBrush="#19FFFFFF"
                                BorderThickness="1"
                                CornerRadius="22">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Layers"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#F6EFE7" />
                                <ItemsControl ItemsSource="{Binding LayerItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="8"
                                                    Margin="{Binding Indent}"
                                                    Background="#120E0C"
                                                    BorderBrush="#19FFFFFF"
                                                    BorderThickness="1"
                                                    CornerRadius="14">
                                                <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto"
                                                      ColumnSpacing="8">
                                                    <Button Grid.Column="0"
                                                            HorizontalContentAlignment="Left"
                                                            Tag="{Binding NodeIdText}"
                                                            Click="OnLayerSelectClick">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Name}" />
                                                            <TextBlock Text="{Binding KindLabel}"
                                                                       FontSize="11"
                                                                       Foreground="#9D9085" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Grid.Column="1"
                                                            Content="V"
                                                            Tag="{Binding NodeIdText}"
                                                            Click="OnLayerVisibilityClick" />
                                                    <Button Grid.Column="2"
                                                            Content="L"
                                                            Tag="{Binding NodeIdText}"
                                                            Click="OnLayerLockClick" />
                                                    <Button Grid.Column="3"
                                                            Content="Up"
                                                            IsEnabled="{Binding CanMoveUp}"
                                                            Tag="{Binding NodeIdText}"
                                                            Click="OnLayerMoveUpClick" />
                                                    <Button Grid.Column="4"
                                                            Content="Down"
                                                            IsEnabled="{Binding CanMoveDown}"
                                                            Tag="{Binding NodeIdText}"
                                                            Click="OnLayerMoveDownClick" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        <Border Padding="16"
                                Background="#B8140F0D"
                                BorderBrush="#19FFFFFF"
                                BorderThickness="1"
                                CornerRadius="22">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Agent Context"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#F6EFE7" />
                                <TextBlock Text="{Binding AgentContextSummaryText}"
                                           TextWrapping="Wrap"
                                           Foreground="#D7CCC2" />
                                <TextBlock Text="{Binding ProposalStatusText}"
                                           Foreground="#F0C898"
                                           FontSize="12" />
                                <TextBlock Text="{Binding ProposalSummaryText}"
                                           FontWeight="SemiBold"
                                           Foreground="#F6EFE7"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding ProposalIssueText}"
                                           IsVisible="{Binding HasProposalIssues}"
                                           Foreground="#F0C898"
                                           TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8">
                                    <Button Content="Approve"
                                            IsEnabled="{Binding CanApproveProposal}"
                                            Click="OnApproveProposalClick" />
                                    <Button Content="Reject"
                                            IsEnabled="{Binding CanRejectProposal}"
                                            Click="OnRejectProposalClick" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
